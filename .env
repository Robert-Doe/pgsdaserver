# ─── Phoenix Ghanaian SDA Church — Server Environment ───
# Copy this to .env and fill in your values

# Database (SQLite for dev, swap to postgresql:// for prod)
DATABASE_URL="file:./dev.db"

# JWT Secrets — CHANGE THESE IN PRODUCTION
JWT_SECRET="pgsda-jwt-secret-change-in-production-2026"
JWT_REFRESH_SECRET="pgsda-refresh-secret-change-in-production-2026"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=5000
NODE_ENV=development
CLIENT_URL="http://localhost:5173"

# Email (optional — for notifications and password resets)
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="Phoenix Ghanaian SDA <noreply@phoenixghanaiansda.org>"

# File uploads
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=52428800  # 50MB in bytes
